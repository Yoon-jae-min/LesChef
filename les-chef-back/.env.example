# LesChef Backend 환경 변수 예시
# 이 파일을 복사해서 .env 로 이름을 바꾼 뒤 값을 채워서 사용하세요.

# 세션 시크릿 키 (최소 32자 이상, 랜덤 문자열 권장)
SESSION_SECRET_KEY=change-this-to-a-long-random-secret-key

# CORS 허용 오리진 (쉼표로 구분)
CORS_ORIGIN=http://localhost:3000,https://localhost:3000

# 서버 설정
SERVER_URL=https://localhost:443
SERVER_ADDRESS=http://localhost:3001
PORT=443

# 프론트엔드 주소
FRONTEND_URL=http://localhost:3000

# SSL 인증서 경로 (프로덕션 필수, 개발 선택)
SSL_KEY_PATH=./src/certs/private-key.pem
SSL_CERT_PATH=./src/certs/certificate.pem

# KAMIS API 설정 (식재료 물가 정보)
KAMIS_API_BASE_URL=https://www.kamis.or.kr/service/price/xml.do
KAMIS_CERT_KEY=your-kamis-cert-key
KAMIS_CERT_ID=your-kamis-cert-id

# 카카오 소셜 로그인 설정
KAKAO_API_KEY=your-kakao-rest-api-key
KAKAO_APP_ADMIN_KEY=your-kakao-admin-key
KAKAO_AUTH_URL=https://kauth.kakao.com
KAKAO_API_URL=https://kapi.kakao.com

# 구글 소셜 로그인
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# 네이버 소셜 로그인
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret

# 환경 설정
NODE_ENV=development

# MongoDB 연결 문자열
DB_CONNECT=your-mongodb-connection-string

# 이메일 발송 설정 (선택)
# 개발용 Gmail 예시
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_APP_PASSWORD=your-gmail-app-password
EMAIL_FROM="LesChef <your-email@gmail.com>"

# 또는 커스텀 SMTP 사용 시 (프로덕션용)
# EMAIL_SERVICE=smtp
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-smtp-username
# SMTP_PASSWORD=your-smtp-password
# EMAIL_FROM="LesChef <noreply@leschef.com>"

