# LesChef Web Frontend 환경 변수 예시
# 이 파일을 복사해서 .env 로 이름을 바꾼 뒤 값을 채워서 사용하세요.

# 프론트엔드 기본 URL (선택)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# 백엔드 API 기본 URL (필수)
# - 이 값만 바꾸면 프론트에서 API 호출/이미지 경로가 전부 같이 따라갑니다.
NEXT_PUBLIC_BACKEND_BASE_URL=http://localhost:3001

# 개발용 HTTPS 인증서 경로 (선택)
SSL_CERT_PATH=./certs/localhost-cert.pem
SSL_KEY_PATH=./certs/localhost-key.pem

# ⚠️ TLS 인증서 검증 끄기 — 로컬 자가서명 HTTPS(server.js 등) 전용
# - 프로덕션·스테이징 .env 에 넣지 마세요 (중간자 공격에 취약).
# - 로컬에서도 필요 없으면 이 줄을 삭제하거나 주석 처리하세요.
# NODE_TLS_REJECT_UNAUTHORIZED=0

# 소셜 로그인 클라이언트 키 (프론트 전용, 공개 가능)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-oauth-client-id
NEXT_PUBLIC_NAVER_CLIENT_ID=your-naver-client-id
NEXT_PUBLIC_KAKAO_REST_API_KEY=your-kakao-rest-api-key

# 빌드 모드
NODE_ENV=development

