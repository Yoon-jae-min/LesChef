# LesChef Backend 환경 변수 예시
# 이 파일을 복사해서 .env 로 이름을 바꾼 뒤 값을 채워서 사용하세요.

# 세션 시크릿 키 — 프로덕션(NODE_ENV=production)에서는 32자 미만이면 서버가 기동하지 않습니다.
# 비밀번호 재설정(비로그인) JWT 서명에도 같은 값이 사용됩니다.
SESSION_SECRET_KEY=change-this-to-a-long-random-secret-key-at-least-32-chars

# CORS 허용 오리진 (쉼표로 구분)
CORS_ORIGIN=http://localhost:3000,https://localhost:3000

# ── 서버 리스닝 (index.ts와 동일하게 동작) ──
# PORT: HTTP·HTTPS 공통 리슨 포트 (미설정 시 기본 3001)
PORT=3001
# 바인드 주소 (기본 0.0.0.0)
# BIND_HOST=0.0.0.0

# 프론트·문서용 공개 베이스 URL (NEXT_PUBLIC_BACKEND_BASE_URL 등과 맞출 것)
SERVER_ADDRESS=http://localhost:3001
# SERVER_URL=https://api.example.com

# 프론트엔드 주소
FRONTEND_URL=http://localhost:3000

# 세션 쿠키 (선택)
# - COOKIE_SECURE 미설정: Node가 HTTPS로 기동하면 true, HTTP면 false
# - 리버스 프록시 뒤에서 TLS 종료만 하고 내부는 HTTP인 경우 등은 true/false 로 명시
# COOKIE_SECURE=true
# COOKIE_SAMESITE=lax
# sameSite=none 사용 시 브라우저 규격상 Secure 필수(서버가 자동으로 secure 처리)
# COOKIE_DOMAIN=

# Helmet Content-Security-Policy (순수 JSON API는 끄는 경우가 많음)
# - 기본: CSP 적용, connect-src 에 CORS_ORIGIN 값들이 포함됨
# - 끄기: HELMET_CSP=off 또는 0 또는 false
# HELMET_CSP=off

# SSL: 두 경로가 모두 설정되고 파일이 실제로 존재하면 → HTTPS로 위 PORT에서 기동
# 개발에서 HTTP만 쓸 때는 비워 두거나, 파일이 없으면 자동으로 HTTP만 사용
# SSL_KEY_PATH=./src/certs/private-key.pem
# SSL_CERT_PATH=./src/certs/certificate.pem

# KAMIS API 설정 (식재료 물가 정보)
KAMIS_API_BASE_URL=https://www.kamis.or.kr/service/price/xml.do
KAMIS_CERT_KEY=your-kamis-cert-key
KAMIS_CERT_ID=your-kamis-cert-id

# 카카오 소셜 로그인 설정
KAKAO_API_KEY=your-kakao-rest-api-key
KAKAO_APP_ADMIN_KEY=your-kakao-admin-key
KAKAO_AUTH_URL=https://kauth.kakao.com
KAKAO_API_URL=https://kapi.kakao.com

# 구글 소셜 로그인
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# 네이버 소셜 로그인
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret

# 환경 설정
NODE_ENV=development

# MongoDB 연결 문자열
DB_CONNECT=your-mongodb-connection-string

# 이메일 발송 설정 (선택)
# 개발용 Gmail 예시
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_APP_PASSWORD=your-gmail-app-password
EMAIL_FROM="LesChef <your-email@gmail.com>"

# 또는 커스텀 SMTP 사용 시 (프로덕션용)
# EMAIL_SERVICE=smtp
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-smtp-username
# SMTP_PASSWORD=your-smtp-password
# EMAIL_FROM="LesChef <noreply@leschef.com>"

# ── 레시피 이미지 저장소 (선택) ──
# 생략 또는 local → public/Image 아래 디스크 저장 (기존 동작)
# s3 → S3 호환 스토리지(R2, AWS S3, MinIO 등)에 업로드, DB에는 퍼블릭 URL 저장
# STORAGE_DRIVER=local
#
# STORAGE_DRIVER=s3
# STORAGE_BUCKET=your-bucket
# STORAGE_ACCESS_KEY_ID=your-access-key
# STORAGE_SECRET_ACCESS_KEY=your-secret-key
# 퍼블릭으로 브라우저가 이미지를 불러올 수 있는 베이스 URL (끝에 / 없음)
# STORAGE_PUBLIC_BASE_URL=https://pub-xxxx.r2.dev
# Cloudflare R2 등: 계정 엔드포인트 (AWS S3는 보통 생략)
# STORAGE_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# STORAGE_REGION=auto
# R2/MinIO 권장: true
# STORAGE_S3_FORCE_PATH_STYLE=true

