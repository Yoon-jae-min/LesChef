# LesChef Web Frontend 환경 변수 예시
# 이 파일을 복사해서 .env 로 이름을 바꾼 뒤 값을 채워서 사용하세요.

# 프론트엔드 기본 URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# 백엔드 API 기본 URL
NEXT_PUBLIC_API_URL=https://localhost:443

# 개별 API 엔드포인트 (필요 시 덮어쓰기)
NEXT_PUBLIC_RECIPE_API_URL=https://localhost:3000/recipe
NEXT_PUBLIC_BOARD_API_URL=https://localhost:3000/board
NEXT_PUBLIC_CUSTOMER_API_URL=https://localhost:3000/customer

# 개발용 HTTPS 인증서 경로 (선택)
SSL_CERT_PATH=./certs/localhost-cert.pem
SSL_KEY_PATH=./certs/localhost-key.pem

# 개발 편의를 위한 TLS 검증 비활성화 (개발 환경에서만 사용)
NODE_TLS_REJECT_UNAUTHORIZED=0

# 소셜 로그인 클라이언트 키 (프론트 전용, 공개 가능)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-oauth-client-id
NEXT_PUBLIC_NAVER_CLIENT_ID=your-naver-client-id
NEXT_PUBLIC_KAKAO_REST_API_KEY=your-kakao-rest-api-key

# 빌드 모드
NODE_ENV=development

